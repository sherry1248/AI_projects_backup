{
  "name": "plugin-manager",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test:hosted": "vitest run src/components/plugin/hosted --exclude \"src/components/plugin/hosted/e2e/**\"",
    "test:hosted:e2e": "playwright test",
    "test:hosted:watch": "vitest src/components/plugin/hosted --exclude \"src/components/plugin/hosted/e2e/**\"",
    "check:hosted": "npm run type-check && npm run check-hosted-tsx && npm run test:hosted && npm run test:hosted:e2e",
    "check-hosted-tsx": "node scripts/check-hosted-tsx.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tanstack/vue-virtual": "^3.0.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "axios": "^1.8.2",
    "dayjs": "^1.11.13",
    "diff": "^8.0.2",
    "element-plus": "^2.8.8",
    "pinia": "^3.0.4",
    "pinyin-pro": "^3.28.1",
    "sucrase": "^3.35.1",
    "vue": "^3.5.25",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "~10.5.1",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "typescript": "~5.9.0",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.1.5"
  }
}
